ignore-workspace-root-check=true

# Default registry — публичный npm. Используется для всего, кроме @capsuletech.
registry=https://registry.npmjs.org/

# @capsuletech идёт в локальный Verdaccio (для тестов nx-release).
# Внутри этого репо @capsuletech/* резолвятся как workspace:* и регистр не дёргают.
# В чужом workspace эта строка имеет смысл только когда Verdaccio запущен
# (см. `pnpm registry` в scripts/) — иначе достаточно убрать её или
# перевести @capsuletech:registry на публичный npm.
@capsuletech:registry=http://localhost:4873/
//localhost:4873/:_authToken=secretVerdaccioToken
