{
  "name": "@capsuletech/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/**"
  ],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "husky",
    "start:workspace": "node packages/cli/bin/capsule.mjs",
    "dev:agent": "pnpm --filter @capsuletech/agent dev",
    "storybook:ui": "pnpm --filter @capsuletech/web-ui storybook",
    "storybook:ui:build": "pnpm --filter @capsuletech/web-ui storybook:build",
    "dev:agent:plugin": "cd plugins/webstorm-agent && ./gradlew runIde",
    "dev:backend": "node scripts/dev-backend.mjs",
    "desktop": "node scripts/desktop.mjs dev",
    "desktop:build": "node scripts/desktop.mjs build",
    "verdaccio:registry": "pnpm nx local-registry",
    "release:local:cli": "node scripts/release-local.mjs --group=cli",
    "release:local:web": "node scripts/release-local.mjs --group=web_base",
    "release:local:all": "node scripts/release-local.mjs --group=all",
    "nx:reset": "nx reset",
    "lint": "biome check --write .",
    "lint:fix": "biome check --apply  --unsafe .",
    "format": "biome format --write .",
    "audit:exports": "node scripts/audit-exports.mjs",
    "test": "pnpm -r --filter \"./packages/**\" --workspace-concurrency=1 test",
    "dev:builders": "pnpm -r --parallel --filter \"./packages/builders/**\" run dev",
    "report": "node scripts/feature-report.mjs",
    "report:list": "node scripts/feature-report.mjs list",
    "report:all": "node scripts/feature-report.mjs all",
    "remote": "pnpm install -g @capsuletech/cli@latest --registry=http://localhost:4873",
    "kill": "npx kill-port 2233 2250"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.15",
    "@nx/devkit": "^22.7.0",
    "@nx/esbuild": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/storybook": "22.6.5",
    "@nx/web": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tanstack/router-cli": "^1.166.39",
    "@tanstack/router-vite-plugin": "^1.166.45",
    "@tauri-apps/cli": "^2.0.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "25.9.0",
    "@vitest/ui": "~4.1.0",
    "enquirer": "^2.4.1",
    "esbuild": "^0.27.0",
    "husky": "^9.1.7",
    "jsdom": "~22.1.0",
    "nx": "22.7.2",
    "prettier": "~3.6.2",
    "publint": "^0.3.21",
    "storybook": "^10",
    "storybook-solidjs-vite": "^10",
    "tailwindcss": "^4.2.4",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.2",
    "verdaccio": "^6.3.2",
    "vite": "^6.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@babel/core": "^7.25.6",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/plugin-syntax-jsx": "^7.24.7",
    "@babel/traverse": "^7.25.6",
    "@babel/types": "^7.25.6",
    "@capsuletech/compliance": "workspace:*",
    "@capsuletech/shared-file-manager": "workspace:*",
    "@clack/prompts": "^1.3.0",
    "@kobalte/core": "^0.13.11",
    "@motionone/solid": "^10.16.4",
    "@nx/vite": "22.6.5",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/solid-router": "^1.169.0",
    "@tanstack/solid-virtual": "^3.13.24",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@xstate/solid": "^2.0.0",
    "babel-plugin-transform-remove-imports": "^1.8.1",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "console-table-printer": "^2.15.0",
    "es-toolkit": "^1.46.0",
    "execa": "^9.6.1",
    "jiti": "2.4.2",
    "lucide-solid": "^1.16.0",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "unplugin-auto-import": "^21.0.0",
    "vite-plugin-dts": "~5.0.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "web-vitals": "^5.2.0",
    "xstate": "^5.0.0",
    "zod": "^4.4.3"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
