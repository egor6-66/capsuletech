    "test:watch": "vitest",
    "prepack": "node scripts/build-native.mjs"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@types/node": "25.9.1",
    "vitest": "~4.1.7"
  }
}
