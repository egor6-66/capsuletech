{
  "$schema": "https://schema.tauri.app/config/2.0.0/schema.json",
  "productName": "Capsule",
  "version": "0.0.0",
  "identifier": "tech.capsule.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../apps/sandbox/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Capsule",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
