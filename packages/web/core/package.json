{
  "name": "@capsuletech/web-core",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:local": "node ../../../scripts/release.mjs --group=web_base -- patch",
    "release:prod": "node ../../../scripts/release.mjs --group=web_base --mode=prod"
  },
  "dependencies": {
    "@capsuletech/web-profiler": "workspace:*",
    "@capsuletech/web-router": "workspace:*",
    "@capsuletech/web-state": "workspace:*",
    "@capsuletech/web-ui": "workspace:*",
    "@capsuletech/web-query": "workspace:*",
    "@capsuletech/shared-zod": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*",
    "@capsuletech/shared-file-manager": "workspace:*",
    "@capsuletech/web-style": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.5"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./create": {
      "types": "./dist/create/index.d.ts",
      "import": "./dist/create.mjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  },
  "files": [
    "dist"
  ]
}
