{
  "name": "@capsuletech/web-editor",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./manifests": {
      "types": "./dist/manifests/index.d.ts",
      "import": "./dist/manifests.mjs",
      "default": "./dist/manifests.mjs"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state.mjs",
      "default": "./dist/state.mjs"
    },
    "./inspector": {
      "types": "./dist/inspector/index.d.ts",
      "import": "./dist/inspector.mjs",
      "default": "./dist/inspector.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@capsuletech/shared-zod": "workspace:*",
    "lucide-solid": "^1.16.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
