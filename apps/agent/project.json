{
  "name": "@capsuletech/agent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/agent/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../packages/cli/bin/capsule.mjs",
        "cwd": "apps/agent",
        "interactive": true,
        "parallel": false
      }
    },
    "serve": {
      "command": "node ../../packages/cli/bin/capsule.mjs dev",
      "options": {
        "cwd": "apps/agent"
      },
      "dependsOn": ["^build"]
    },
    "build": {
      "command": "node ../../packages/cli/bin/capsule.mjs build",
      "options": {
        "cwd": "apps/agent"
      },
      "dependsOn": ["^build"]
    }
  }
}
